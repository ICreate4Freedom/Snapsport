{
  "expo": {
    "name": "SnapsPort",
    "slug": "snapsport",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.snapsport.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSPhotoLibraryAddUsageDescription": "SnapsPort saves your Snapchat memories directly to your photo library.",
        "NSPhotoLibraryUsageDescription": "SnapsPort saves your Snapchat memories directly to your photo library.",
        "LSApplicationQueriesSchemes": [
          "snapchat",
          "googlegmail",
          "ms-outlook",
          "ymail",
          "readdle-spark",
          "protonmail"
        ],
        "CFBundleDocumentTypes": [
          {
            "CFBundleTypeName": "ZIP Archive",
            "CFBundleTypeRole": "Viewer",
            "LSHandlerRank": "Alternate",
            "LSItemContentTypes": [
              "com.pkware.zip-archive",
              "public.zip-archive",
              "org.gnu.gnu-zip-archive"
            ]
          }
        ],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.snapsport.app",
      "permissions": [
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.ACCESS_MEDIA_LOCATION",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_AUDIO"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [
            {
              "mimeType": "application/zip"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "plugins": [
      "expo-router",
      "expo-document-picker",
      [
        "expo-media-library",
        {
          "photosPermission": "SnapsPort saves your Snapchat memories directly to your photo library.",
          "savePhotosPermission": "SnapsPort needs permission to save photos to your library.",
          "isAccessMediaLocationEnabled": true
        }
      ]
    ],
    "scheme": "snapsport",
    "extra": {
      "router": {
        "origin": false
      },
      "FREE_TIER_LIMIT": 50,
      "eas": {
        "projectId": "3759f5b0-38e1-4463-8bda-470c29de0a01"
      }
    }
  }
}
